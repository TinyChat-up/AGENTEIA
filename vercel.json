{
  "crons": [
    {
      "path": "/api/orchestrator?cycle=daily",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/orchestrator?cycle=weekly",
      "schedule": "0 0 * * 0"
    }
  ],
  "functions": {
    "src/app/api/orchestrator/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/agent-run/route.ts": {
      "maxDuration": 300
    }
  }
}
